{
  "name": "secure-exam-system",
  "version": "1.0.3",
  "description": "SecurePro AI Exam Proctoring System",
  "main": "main.js",
  "author": "Admin",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.securepro.exam",
    "productName": "SecurePro",
    "copyright": "Copyright © 2025 SecurePro",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "dmg": {
      "title": "SecurePro Installer",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SecurePro"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SupratheekReddy",
        "repo": "securepro-releases",
        "releaseType": "release"
      }
    ],
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.map"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "electron-updater": "^6.3.9"
  }
}